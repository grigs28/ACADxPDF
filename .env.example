# ACADxPDF Configuration
# Copy this file to .env and modify as needed.

# --- AutoCAD ---
# Path to accoreconsole.exe
ACAD_PATH=C:\Autodesk\AutoCAD 2020\accoreconsole.exe
# Unit name in AutoCAD language ("毫米" for Chinese, "MM" for English)
ACAD_UNIT=毫米

# --- Plotting ---
# PC3 printer name
PRINTER=DWG To PDF.pc3
# CTB plot style
PLOT_STYLE=monochrome.ctb
# Conversion timeout per file (seconds)
TIMEOUT=180

# --- API ---
API_HOST=0.0.0.0
API_PORT=5000
